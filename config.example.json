{
  "settings": {
    "poll_interval_ms": 1000,
    "notifications": true
  },
  "triggers": [
    {
      "event": "Connected",
      "script": "notify-send 'Scape' 'Headset connected — $SCAPE_DEVICE'",
      "label": "Connect notification",
      "enabled": true
    },
    {
      "event": "Disconnected",
      "script": "notify-send 'Scape' 'Headset disconnected'",
      "label": "Disconnect notification",
      "enabled": true
    }
  ]
}
